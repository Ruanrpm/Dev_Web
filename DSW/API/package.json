  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --inspect -r tsconfig-paths/register --transpile-only --ignore-watch node_modules src/shared/http/server.ts",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:run": "npm run typeorm -- migration:run -d src/shared/typeorm/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate -d src/shared/typeorm/data-source.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "expres": "^0.0.5",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "ts-node-dev": "^2.0.0",
    "typeorm": "^0.3.28",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsconfig-paths": "^4.2.0"
  }
}
